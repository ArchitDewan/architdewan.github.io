---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Projects from '../components/sections/Projects.astro';

const allProjects = await getCollection('projects');
const homeProjects = allProjects
  .filter((project) => project.data.homePinned)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<MainLayout title="Archit Dewan | Developer Portfolio" description="Minimal portfolio of Archit Dewan, CS & Math at McMaster University.">
  <main>
    <Hero />
    <Projects projects={homeProjects.slice(0, 2)} heading="Selected Work" description="A quick snapshot. Explore the full archive for more projects." />
  </main>
</MainLayout>
