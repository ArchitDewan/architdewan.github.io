---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="404 | Not Found" description="Page not found.">
  <main class="section-shell py-24">
    <p class="eyebrow">404</p>
    <h1 class="mt-4 text-4xl font-semibold" style="font-family: 'Space Grotesk', sans-serif;">Page not found.</h1>
    <p class="mt-4 text-[var(--ink-muted)]">The page you requested does not exist.</p>
    <a href="/" class="mt-8 inline-block rounded-full border border-[var(--line)] px-5 py-2 text-sm">Return home</a>
  </main>
</MainLayout>
