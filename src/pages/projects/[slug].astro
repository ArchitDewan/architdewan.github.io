---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import { getStackBadgeClass } from '../../utils/stackBadgeColor';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<MainLayout title={`${project.data.title} | Project Case Study`} description={project.data.summary}>
  <main class="section-shell py-20">
    <a href="/projects" class="text-sm underline decoration-[var(--line)] underline-offset-4">Back to all projects</a>

    <header class="mt-8 border-b border-[var(--line)] pb-8">
      <p class="eyebrow">Case Study</p>
      <h1 class="mt-3 text-4xl font-semibold md:text-5xl" style="font-family: 'Space Grotesk', sans-serif;">{project.data.title}</h1>
      <p class="mt-4 max-w-2xl text-base text-[var(--ink-muted)]">{project.data.summary}</p>

      <div class="mt-6 flex flex-wrap gap-2">
        {project.data.stack.map((item) => (
          <span class={`rounded-full border px-3 py-1 text-xs ${getStackBadgeClass(item)}`}>{item}</span>
        ))}
      </div>

      <div class="mt-6 flex flex-wrap gap-4 text-sm">
        <a href={project.data.repoUrl} target="_blank" rel="noreferrer" class="underline decoration-[var(--line)] underline-offset-4">Repository</a>
        {project.data.liveUrl && (
          <a href={project.data.liveUrl} target="_blank" rel="noreferrer" class="underline decoration-[var(--line)] underline-offset-4">Live Demo</a>
        )}
      </div>
    </header>

    <section class="mt-10 grid gap-4 rounded-2xl border border-[var(--line)] bg-[var(--surface)] p-6 text-sm md:grid-cols-3">
      <div>
        <h2 class="font-semibold">Problem</h2>
        <p class="mt-2 text-[var(--ink-muted)]">{project.data.problem}</p>
      </div>
      <div>
        <h2 class="font-semibold">Approach</h2>
        <p class="mt-2 text-[var(--ink-muted)]">{project.data.approach}</p>
      </div>
      <div>
        <h2 class="font-semibold">Outcome</h2>
        <p class="mt-2 text-[var(--ink-muted)]">{project.data.outcome}</p>
      </div>
    </section>

    <article class="prose prose-neutral mt-12 max-w-none prose-headings:font-semibold prose-headings:text-[var(--ink)]">
      <Content />
    </article>
  </main>
</MainLayout>
