---
import type { CollectionEntry } from 'astro:content';
import { getStackBadgeClass } from '../../utils/stackBadgeColor';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data, slug } = project;
const shownStack = data.stack.slice(0, 5);
const stackOverflow = data.stack.length - shownStack.length;
---

<article class="group rounded-2xl border border-[var(--line)] bg-[var(--surface)] p-6 transition hover:-translate-y-0.5 hover:border-[var(--ink)]">
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-xl font-semibold" style="font-family: 'Space Grotesk', sans-serif;">{data.title}</h3>
    <span class="text-xs uppercase tracking-[0.14em] text-[var(--ink-muted)]">{data.role}</span>
  </div>

  <p class="mt-3 text-sm leading-relaxed text-[var(--ink-muted)]">{data.summary}</p>

  <div class="mt-4">
    <p class="text-xs uppercase tracking-[0.14em] text-[var(--ink-muted)]">Stack</p>
    <div class="mt-2 flex flex-wrap gap-2">
      {shownStack.map((item) => (
        <span class={`rounded-full border px-3 py-1 text-xs ${getStackBadgeClass(item)}`}>{item}</span>
      ))}
      {stackOverflow > 0 && <span class="rounded-full border border-[var(--line)] px-3 py-1 text-xs">+{stackOverflow}</span>}
    </div>
  </div>

  <div class="mt-4">
    <p class="text-xs uppercase tracking-[0.14em] text-[var(--ink-muted)]">Skills Applied</p>
    <p class="mt-2 text-sm text-[var(--ink-muted)]">{data.skillsApplied.join(' • ')}</p>
  </div>

  <div class="mt-6 flex flex-wrap gap-4 text-sm">
    <a href={`/projects/${slug}/`} class="underline decoration-[var(--line)] underline-offset-4 transition group-hover:decoration-[var(--ink)]">Case Study</a>
    <a href={data.repoUrl} target="_blank" rel="noreferrer" class="underline decoration-[var(--line)] underline-offset-4 transition group-hover:decoration-[var(--ink)]">Repository</a>
    {data.liveUrl && (
      <a href={data.liveUrl} target="_blank" rel="noreferrer" class="underline decoration-[var(--line)] underline-offset-4 transition group-hover:decoration-[var(--ink)]">Live Demo</a>
    )}
  </div>
</article>
