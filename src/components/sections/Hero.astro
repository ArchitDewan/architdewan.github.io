<section class="relative reveal-up min-h-[100svh]">
  <div class="section-shell flex min-h-[100svh] items-center py-8 md:py-12">
    <div class="w-full max-w-3xl">
    <p class="eyebrow">Archit Dewan</p>
    <h1 class="mt-4 text-5xl font-semibold leading-tight md:text-7xl" style="font-family: 'Space Grotesk', sans-serif;">
      Archit Dewan
    </h1>
    <p class="mt-6 max-w-2xl text-base leading-relaxed text-[var(--ink-muted)] md:text-lg">CS & Math @ McMaster University. </p>
    <div class="mt-8 flex flex-wrap gap-4">
      <a href="/projects" class="rounded-full border border-[var(--line)] px-5 py-2 text-sm font-medium transition hover:border-[var(--ink)]">View All Projects</a>
    </div>
    <div class="mt-7 flex items-center gap-3">
      <nav aria-label="Contact links" class="flex items-center gap-3">
      <a
        href="https://github.com/ArchitDewan"
        target="_blank"
        rel="noreferrer"
        aria-label="GitHub"
        class="flex h-10 w-10 items-center justify-center rounded-full border border-[var(--line)] transition hover:border-[var(--ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--ink)]"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
          <path d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.1c-3.3.7-4-1.6-4-1.6a3.1 3.1 0 0 0-1.3-1.7c-1.1-.8.1-.8.1-.8a2.5 2.5 0 0 1 1.8 1.2 2.6 2.6 0 0 0 3.5 1 2.7 2.7 0 0 1 .8-1.7c-2.7-.3-5.5-1.3-5.5-6A4.7 4.7 0 0 1 5.5 8a4.4 4.4 0 0 1 .1-3.2s1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2a4.4 4.4 0 0 1 .1 3.2 4.7 4.7 0 0 1 1.2 3.2c0 4.8-2.8 5.7-5.5 6a3 3 0 0 1 .9 2.3v3.4c0 .3.2.7.8.6A12 12 0 0 0 12 .5Z"></path>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/architdewan/"
        target="_blank"
        rel="noreferrer"
        aria-label="LinkedIn"
        class="flex h-10 w-10 items-center justify-center rounded-full border border-[var(--line)] transition hover:border-[var(--ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--ink)]"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
          <path d="M20.4 20.5h-3.6v-5.7c0-1.4 0-3.1-1.9-3.1s-2.2 1.5-2.2 3v5.8H9.1V9h3.4v1.6h.1c.5-.9 1.7-1.9 3.5-1.9 3.8 0 4.5 2.5 4.5 5.7v6.1ZM5 7.5a2.1 2.1 0 1 1 0-4.2 2.1 2.1 0 0 1 0 4.2ZM6.8 20.5H3.2V9h3.6v11.5Z"></path>
        </svg>
      </a>
      <button
        type="button"
        data-copy-email-hero
        data-email="architdewan2006@gmail.com"
        aria-label="Copy email address"
        class="flex h-10 w-10 items-center justify-center rounded-full border border-[var(--line)] transition hover:border-[var(--ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--ink)]"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
          <path d="M20 5H4a2 2 0 0 0-2 2v10c0 1.1.9 2 2 2h16a2 2 0 0 0 2-2V7c0-1.1-.9-2-2-2Zm0 2-8 5L4 7h16Zm0 10H4V9.2l8 5 8-5V17Z"></path>
        </svg>
      </button>
      </nav>
      <span data-copy-status-hero class="text-xs text-[var(--ink-muted)]" aria-live="polite"></span>
    </div>
    </div>
  </div>
  <button
    type="button"
    data-scroll-projects
    class="scroll-cue absolute bottom-8 right-8 hidden items-center gap-2 text-xs uppercase tracking-[0.2em] text-[var(--ink-muted)] transition hover:text-[var(--ink)] md:flex"
    aria-label="Scroll to projects"
  >
    <span>Scroll</span>
    <span aria-hidden="true">↓</span>
  </button>
</section>

<script is:inline>
  const copyBtn = document.querySelector('[data-copy-email-hero]');
  const status = document.querySelector('[data-copy-status-hero]');
  const scrollBtn = document.querySelector('[data-scroll-projects]');
  const projectsSection = document.querySelector('#projects');

  copyBtn?.addEventListener('click', async () => {
    const email = copyBtn.getAttribute('data-email');
    if (!email) return;

    try {
      await navigator.clipboard.writeText(email);
      if (status) status.textContent = 'Copied email';
    } catch {
      if (status) status.textContent = 'Copy failed';
    }

    setTimeout(() => {
      if (status) status.textContent = '';
    }, 1500);
  });

  scrollBtn?.addEventListener('click', () => {
    if (projectsSection) {
      projectsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } else {
      window.scrollTo({ top: window.innerHeight, behavior: 'smooth' });
    }
  });
</script>
